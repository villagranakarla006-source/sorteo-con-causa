rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /numbers/{numberId} {
      allow read: if true;
      allow create, update: if request.resource.data.status == 'reserved'
        || request.auth != null;
      allow delete: if request.auth != null;
    }

    match /participants/{participantId} {
      allow create: if request.resource.data.name is string
        && request.resource.data.phone is string
        && request.resource.data.numbers is list
        && request.resource.data.status in ['pending_payment','pending_transfer','pending_cash','receipt_received'];

      // Permite que un participante complete su pago desde el sitio.
      // La actualización pública solo puede añadir el comprobante y cambiar
      // un registro pendiente a "receipt_received".
      allow read: if request.auth != null;
      allow update: if request.auth != null || (
        resource.data.status in ['pending_payment','pending_transfer','pending_cash']
        && request.resource.data.status in ['receipt_received','pending_cash']
        && request.resource.data.phone == resource.data.phone
        && request.resource.data.numbers == resource.data.numbers
        && request.resource.data.name == resource.data.name
      );
      allow delete: if request.auth != null;
    }

    match /audit/{auditId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
